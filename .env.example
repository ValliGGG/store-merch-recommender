# ARTMiE Recommender — environment
#
# Locally: copy to .env, OR rely on the shared token store at
#   C:/Users/Valerian/Desktop/Claude 1TEST/shopify-reports/.env
# (scripts/lib/config.py reads that path by default; override with
#  ARTMIE_SHARED_ENV=/path/to/.env).
#
# On GitHub Actions these are provided as repository secrets — see
# docs/github_secrets.md. Never commit real tokens.
#
# Each store names its own URL + token pair. config.load(<store>) reads ONLY
# that store's pair, so tokens are never mixed between stores.

# SK — main store; also serves AT/HR/DE/GR/IT/SI/BG markets via Shopify Markets
ARTMIE_SK_STORE_URL=20a254-6e.myshopify.com
ARTMIE_SK_API_TOKEN=shpat_xxx

# CZ — czech republic (CZK)
ARTMIE_CZ_STORE_URL=cz-artmie.myshopify.com
ARTMIE_CZ_API_TOKEN=shpat_xxx

# PL — poland (PLN) — low order history -> borrow mode
ARTMIE_PL_STORE_URL=pl-artmie.myshopify.com
ARTMIE_PL_API_TOKEN=shpat_xxx

# HU — hungary (HUF)
ARTMIE_HU_STORE_URL=hu-artmie.myshopify.com
ARTMIE_HU_API_TOKEN=shpat_xxx

# RO — romania (RON)
ARTMIE_RO_STORE_URL=ro-artmie.myshopify.com
ARTMIE_RO_API_TOKEN=shpat_xxx

# MK — north macedonia (MKD)
ARTMIE_MK_STORE_URL=mk-artmie.myshopify.com
ARTMIE_MK_API_TOKEN=shpat_xxx

# RS — serbia (RSD)
ARTMIE_RS_STORE_URL=rs-artmie.myshopify.com
ARTMIE_RS_API_TOKEN=shpat_xxx

# BA — bosnia & herzegovina (BAM)
ARTMIE_BA_STORE_URL=ba-artmie.myshopify.com
ARTMIE_BA_API_TOKEN=shpat_xxx

# NOTE: there is intentionally NO ARTMIE_BG_* here — BG is a market inside the
# SK store (Shopify Markets), not a standalone Shopify store.
